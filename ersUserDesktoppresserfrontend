<!doctype html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>The Presser</title>

  <!-- Fonts -->
  <link href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,700,900&display=swap" rel="stylesheet">

  <!-- Supabase client -->
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

  <style>
    :root {
      --text-xs: clamp(0.75rem, 0.7rem + 0.25vw, 0.875rem);
      --text-sm: clamp(0.875rem, 0.8rem + 0.35vw, 1rem);
      --text-base: clamp(1rem, 0.95rem + 0.25vw, 1.125rem);
      --text-lg: clamp(1.125rem, 1rem + 0.75vw, 1.5rem);
      --text-xl: clamp(1.6rem, 1.1rem + 2vw, 2.7rem);
      --text-2xl: clamp(2.4rem, 1rem + 4vw, 5.2rem);

      --space-2: 0.5rem;
      --space-3: 0.75rem;
      --space-4: 1rem;
      --space-5: 1.25rem;
      --space-6: 1.5rem;
      --space-8: 2rem;
      --space-10: 2.5rem;
      --space-12: 3rem;

      --color-text: #f8fbff;
      --color-text-muted: rgba(248,251,255,0.78);
      --color-text-faint: rgba(248,251,255,0.5);
      --color-border: rgba(255,255,255,0.14);
      --color-warning: #ff8b5c;
      --color-danger: #ff5f5f;
      --color-success: #7bd88f;

      --radius-md: 0.9rem;
      --radius-lg: 1.25rem;
      --radius-full: 9999px;

      --font-body: 'Satoshi', Inter, sans-serif;
      --transition: 220ms cubic-bezier(0.16, 1, 0.3, 1);
    }

    * { box-sizing: border-box; }
    html, body { margin: 0; min-height: 100%; }
    body {
      font-family: var(--font-body);
      background:#05070b;
      color: var(--color-text);
      overflow:hidden;
    }
    button, input { font: inherit; }
    button { cursor:pointer; }

    .app { position:relative; min-height:100vh; overflow:hidden; }

    .bg {
      position:absolute; inset:0;
      background:
        linear-gradient(180deg, rgba(0,0,0,.48), rgba(0,0,0,.62)),
        url('./assets/thepressserchair.jpg') center center / cover no-repeat;
      transform:scale(1.02);
    }
    .bg::after {
      content:'';
      position:absolute; inset:0;
      background:linear-gradient(90deg,
        rgba(0,0,0,.84) 0%,
        rgba(0,0,0,.56) 22%,
        rgba(0,0,0,.08) 45%,
        rgba(0,0,0,.08) 55%,
        rgba(0,0,0,.56) 78%,
        rgba(0,0,0,.84) 100%);
    }

    .shell {
      position:relative; z-index:1;
      min-height:100vh;
      display:grid;
      grid-template-columns:minmax(280px,34vw) 1fr;
      gap:var(--space-6);
      padding:clamp(var(--space-4),3vw,var(--space-8));
      max-width:1280px;
      margin:0 auto;
    }

    .brand {
      display:flex;
      flex-direction:column;
      justify-content:space-between;
      padding:var(--space-6) 0;
    }

    .title {
      font-size:var(--text-2xl);
      line-height:.92;
      font-weight:900;
      letter-spacing:-.05em;
      max-width:5ch;
      text-shadow:0 8px 24px rgba(0,0,0,.45);
    }

    .panel {
      width:min(620px,100%);
      margin:auto 0 auto auto;
      display:grid;
      gap:var(--space-5);
      justify-items:center;
      text-align:center;
      padding:clamp(var(--space-6),2vw,var(--space-8));
      background:linear-gradient(180deg, rgba(255,255,255,.05), rgba(255,255,255,.02));
      border:1px solid var(--color-border);
      border-radius:var(--radius-lg);
      backdrop-filter:blur(10px);
      max-height:calc(100vh - 2 * clamp(var(--space-4),3vw,var(--space-8)));
      overflow:auto;
    }

    .hidden { display:none !important; }

    .tagline {
      font-size:var(--text-xl);
      font-weight:700;
      line-height:1.08;
      max-width:15ch;
    }

    .helper, .note, .status-copy {
      font-size:var(--text-sm);
      color:var(--color-text-muted);
      max-width:40ch;
      line-height:1.6;
    }

    .actions {
      display:flex;
      flex-wrap:wrap;
      gap:var(--space-3);
      justify-content:center;
    }

    .btn {
      min-width:170px;
      min-height:52px;
      padding:0 var(--space-6);
      border:none;
      border-radius:var(--radius-full);
      font-size:var(--text-sm);
      font-weight:700;
      letter-spacing:.04em;
      text-transform:uppercase;
      transition:
        transform var(--transition),
        background var(--transition),
        color var(--transition),
        border-color var(--transition);
      text-decoration:none;
      display:inline-flex;
      align-items:center;
      justify-content:center;
    }
    .btn:hover { transform:translateY(-2px); }

    .btn-primary { background:#fff; color:#05070b; }
    .btn-secondary { background:transparent; color:#fff; border:1px solid var(--color-border); }
    .btn-success { background:var(--color-success); color:#041108; }

    .question-wrap {
      width:min(780px,100%);
      margin:auto 0 auto auto;
    }
    .question-card {
      display:grid;
      gap:var(--space-4);
      background:rgba(7,10,16,.56);
      border:1px solid rgba(255,255,255,.12);
      border-radius:var(--radius-lg);
      padding:clamp(var(--space-5),2vw,var(--space-8));
      backdrop-filter:blur(10px);
    }
    .question-text {
      font-size:clamp(1.35rem, 1rem + 1.6vw, 2.2rem);
      line-height:1.12;
      font-weight:800;
      max-width:22ch;
    }

    .status-row {
      display:flex;
      flex-wrap:wrap;
      align-items:center;
      justify-content:space-between;
      gap:var(--space-4);
    }

    .question-meta { display:grid; gap:var(--space-2); }
    .question-label {
      font-size:var(--text-xs);
      text-transform:uppercase;
      letter-spacing:.18em;
      color:var(--color-text-faint);
    }

    .progress { display:flex; gap:var(--space-2); }
    .dot {
      width:12px; height:12px;
      border-radius:50%;
      background:rgba(255,255,255,.16);
      border:1px solid rgba(255,255,255,.18);
    }
    .dot.active { background:#fff; }
    .dot.done { background:rgba(255,255,255,.45); }

    .timer {
      display:flex;
      align-items:center;
      gap:var(--space-3);
      padding:var(--space-3) var(--space-4);
      border-radius:var(--radius-full);
      background:rgba(255,255,255,.06);
      border:1px solid rgba(255,255,255,.1);
    }
    .timer-ring {
      width:56px; height:56px;
      border-radius:50%;
      display:grid;
      place-items:center;
      background:conic-gradient(#fff calc(var(--progress,100) * 1%), rgba(255,255,255,.12) 0);
    }
    .timer-core {
      width:42px; height:42px;
      border-radius:50%;
      display:grid;
      place-items:center;
      background:#06080c;
      font-weight:800;
      font-size:var(--text-sm);
    }
    .timer-copy { display:grid; gap:2px; text-align:left; }
    .timer-copy strong { font-size:var(--text-lg); line-height:1; }
    .timer-copy span {
      font-size:var(--text-xs);
      text-transform:uppercase;
      letter-spacing:.16em;
      color:var(--color-text-faint);
    }
    .timer.warning .timer-ring {
      background:conic-gradient(var(--color-warning) calc(var(--progress,100) * 1%), rgba(255,139,92,.16) 0);
    }
    .timer.warning .timer-core,
    .timer.warning strong { color:var(--color-warning); }
    .timer.danger .timer-ring {
      background:conic-gradient(var(--color-danger) calc(var(--progress,100) * 1%), rgba(255,95,95,.16) 0);
    }
    .timer.danger .timer-core,
    .timer.danger strong { color:var(--color-danger); }

    .audio-bar {
      position:relative;
      height:54px;
      border-radius:var(--radius-md);
      overflow:hidden;
      background:rgba(255,255,255,.06);
      border:1px solid rgba(255,255,255,.1);
    }
    .audio-wave {
      position:absolute;
      inset:0;
      background:repeating-linear-gradient(
        90deg,
        rgba(255,255,255,.08) 0 6px,
        rgba(255,255,255,.18) 6px 10px,
        rgba(255,255,255,.08) 10px 16px
      );
    }
    .audio-playhead {
      position:absolute;
      top:0; left:0; bottom:0;
      width:24%;
      background:linear-gradient(90deg, rgba(255,255,255,.24), rgba(255,255,255,.04));
      animation:scan 2.2s linear infinite;
    }
    @keyframes scan {
      0% { transform:translateX(-20%); }
      100% { transform:translateX(340%); }
    }

 